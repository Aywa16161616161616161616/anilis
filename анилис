    function findEventDescription(region, date) {
        const cleanDate = date.trim();
        const found = knowledgeBase.find(ev => ev.region === region && ev.date === cleanDate);
        if (found) return found.event;
        return region;
    }

    function extractAllEvents() {
        const events = [];
        finalTable.forEach((row) => {
            const century = row[0];
            if (century === "Век") return;
            for (let col = 1; col < row.length; col++) {
                const cell = row[col]?.trim() || '';
                if (cell !== '') {
                    const region = regions[col-1];
                    const parts = cell.split(',').map(s => s.trim());
                    parts.forEach(datePart => {
                        if (datePart) {
                            events.push({
                                century,
                                region,
                                date: datePart,
                                description: findEventDescription(region, datePart)
                            });
                        }
                    });
                }
            }
        });
        return events;
    }

    const allEvents = extractAllEvents();
    let currentView = 'table';
    let currentEvent = null;

    const viewContainer = document.getElementById('viewContainer');
    const showTableBtn = document.getElementById('showTableBtn');
    const showMatchBtn = document.getElementById('showMatchBtn');
    const showChronoOrderBtn = document.getElementById('showChronoOrderBtn');

    function setActiveButton(activeBtn) {
        [showTableBtn, showMatchBtn, showChronoOrderBtn].forEach(b => b.classList.remove('active-btn'));
        activeBtn.classList.add('active-btn');
    }

    function renderTableView() {
        setActiveButton(showTableBtn);
        let html = `<table><thead><tr>`;
        finalTable[0].forEach(cell => html += `<th>${cell}</th>`);
        html += `</tr></thead><tbody>`;

        for (let i = 1; i < finalTable.length; i++) {
            const row = finalTable[i];
            html += '<tr>';
            html += `<td>${row[0]}</td>`;
            for (let j = 1; j < row.length; j++) {
                const cell = row[j]?.trim() || '';
                if (cell === '') {
                    html += `<td></td>`;
                } else {
                    const region = regions[j-1];
                    const dates = cell.split(',').map(d => d.trim());
                    let linksHtml = '';
                    dates.forEach(d => {
                        if (d) linksHtml += `<button class="date-link" data-region="${region}" data-date="${d}" data-century="${row[0]}">${d}</button> `;
                    });
                    html += `<td>${linksHtml}</td>`;
                }
            }
            html += '</tr>';
        }
        html += `</tbody></table><p class="footnote">🔍 Кликните по дате — откроется событие.</p>`;
        viewContainer.innerHTML = html;

        document.querySelectorAll('.date-link').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const region = e.target.dataset.region;
                const date = e.target.dataset.date;
                const century = e.target.dataset.century;
                const description = findEventDescription(region, date);
                currentEvent = { region, date, description, century };
                currentView = 'event';
                renderEventView();
            });
        });
    }

    function renderEventView() {
        if (!currentEvent) return;
        const html = `
            <div class="event-description-box">
                <div class="event-title">📍 ${currentEvent.region}</div>
                <div class="event-region">${currentEvent.century} век · дата: ${currentEvent.date}</div>
                <div class="event-desc">${currentEvent.description}</div>
                <a href="#" class="back-link" id="backToTableLink">← Обратно к таблице</a>
            </div>
        `;
        viewContainer.innerHTML = html;
        document.getElementById('backToTableLink').addEventListener('click', (e) => {
            e.preventDefault();
            currentView = 'table';
            renderTableView();
        });
    }

    // ============ НАЙДИ ПАРУ — ДВЕ КОЛОНКИ ============
    function renderMatchGame() {
        setActiveButton(showMatchBtn);
        const pairs = [...allEvents].sort(() => 0.5 - Math.random()).slice(0, 6);
        
        // Разделяем даты и события
        const dateCards = [];
        const eventCards = [];
        pairs.forEach((p, idx) => {
            dateCards.push({ type: 'date', value: p.date, pairId: 'pair' + idx, region: p.region });
            eventCards.push({ type: 'event', value: p.description, pairId: 'pair' + idx, region: p.region });
        });
        
        // Перемешиваем каждую колонку отдельно
        dateCards.sort(() => 0.5 - Math.random());
        eventCards.sort(() => 0.5 - Math.random());

        let selectedDate = null;
        let selectedEvent = null;
        let matchedCount = 0;
        let attempts = 0;

        function clearSelections() {
            if (selectedDate) {
                selectedDate.el.classList.remove('selected');
                selectedDate = null;
            }
            if (selectedEvent) {
                selectedEvent.el.classList.remove('selected');
                selectedEvent = null;
            }
        }

        function tryMatch() {
            if (!selectedDate || !selectedEvent) return;
            attempts++;
            document.getElementById('attemptCounter').textContent = attempts;

            if (selectedDate.card.pairId === selectedEvent.card.pairId) {
                // Правильно!
                selectedDate.el.classList.add('matched');
                selectedEvent.el.classList.add('matched');
                selectedDate.el.classList.remove('selected');
                selectedEvent.el.classList.remove('selected');
                matchedCount++;
                document.getElementById('matchCounter').textContent = matchedCount;
                selectedDate = null;
                selectedEvent = null;

                if (matchedCount === pairs.length) {
                    setTimeout(() => {
                        document.getElementById('matchResult').innerHTML = `<div class="result-message result-success">🎉 Все пары найдены за ${attempts} попыток!</div>`;
                    }, 400);
                }
            } else {
                // Неправильно
                selectedDate.el.classList.add('wrong-flash');
                selectedEvent.el.classList.add('wrong-flash');
                const sd = selectedDate;
                const se = selectedEvent;
                setTimeout(() => {
                    sd.el.classList.remove('wrong-flash', 'selected');
                    se.el.classList.remove('wrong-flash', 'selected');
                }, 500);
                selectedDate = null;
                selectedEvent = null;
            }
        }

        function renderGameHTML() {
            let datesHtml = '';
            dateCards.forEach((card, idx) => {
                const matched = card.matched ? 'matched' : '';
                datesHtml += `<div class="match-card match-card-date ${matched}" data-type="date" data-idx="${idx}">${card.value}</div>`;
            });

            let eventsHtml = '';
            eventCards.forEach((card, idx) => {
                const matched = card.matched ? 'matched' : '';
                eventsHtml += `<div class="match-card match-card-event ${matched}" data-type="event" data-idx="${idx}">${card.value}</div>`;
            });

            const html = `
                <div style="padding:10px;">
                    <h3 style="color:#113459;text-align:center;">🎯 Найди пару: дата + событие</h3>
                    <p class="instruction-text">Выберите ДАТУ (слева) и СОБЫТИЕ (справа) — они соединятся</p>
                    <div class="score-panel">Попытки: <span id="attemptCounter">0</span> | Найдено: <span id="matchCounter">0</span>/6</div>
                    <div class="match-game-container">
                        <div class="match-column">
                            <h4>📅 Даты</h4>
                            <div id="datesColumn">${datesHtml}</div>
                        </div>
                        <div class="match-column">
                            <h4>📜 События</h4>
                            <div id="eventsColumn">${eventsHtml}</div>
                        </div>
                    </div>
                    <div id="matchResult" style="text-align:center;margin-top:15px;"></div>
                    <button class="primary-btn outline" id="resetMatchBtn" style="display:block;margin:20px auto;">🔄 Новые пары</button>
                </div>
            `;
            viewContainer.innerHTML = html;

            // Привязываем события к датам
            document.querySelectorAll('.match-card-date').forEach(el => {
                if (el.classList.contains('matched')) return;
                el.addEventListener('click', () => {
                    if (el.classList.contains('wrong-flash')) return;
                    const idx = parseInt(el.dataset.idx);
                    // Снимаем предыдущее выделение с дат
                    document.querySelectorAll('.match-card-date.selected').forEach(e => e.classList.remove('selected'));
                    el.classList.add('selected');
                    selectedDate = { el, card: dateCards[idx] };
                    tryMatch();
                });
            });

            // Привязываем события к карточкам событий
            document.querySelectorAll('.match-card-event').forEach(el => {
                if (el.classList.contains('matched')) return;
                el.addEventListener('click', () => {
                    if (el.classList.contains('wrong-flash')) return;
                    const idx = parseInt(el.dataset.idx);
                    // Снимаем предыдущее выделение с событий
                    document.querySelectorAll('.match-card-event.selected').forEach(e => e.classList.remove('selected'));
                    el.classList.add('selected');
                    selectedEvent = { el, card: eventCards[idx] };
                    tryMatch();
                });
            });

            document.getElementById('resetMatchBtn').addEventListener('click', renderMatchGame);
        }

        renderGameHTML();
    }

    // ============ ХРОНОЛОГИЧЕСКИЙ ПОРЯДОК ============
    function renderChronoOrderGame() {
        setActiveButton(showChronoOrderBtn);
        const selectedEvents = [...allEvents].sort(() => 0.5 - Math.random()).slice(0, 6);

        function getFirstYear(dateStr) {
            const match = dateStr.match(/(\d+)/);
            return match ? parseInt(match[1]) : 0;
        }
        const correctOrder = [...selectedEvents].sort((a, b) => getFirstYear(a.date) - getFirstYear(b.date));
        const shuffledEvents = [...selectedEvents].sort(() => 0.5 - Math.random());

        function renderList() {
            const listContainer = document.getElementById('chronoList');
            let itemsHtml = '';
            shuffledEvents.forEach((ev, idx) => {
                const isFirst = idx === 0;
                const isLast = idx === shuffledEvents.length - 1;
                itemsHtml += `
                    <div class="chrono-item" data-idx="${idx}">
                        <span class="chrono-number">${idx + 1}</span>
                        <span class="chrono-text">${ev.region} — ${ev.description}</span>
                        <div class="chrono-arrows">
                            <button class="arrow-btn move-up" data-idx="${idx}" ${isFirst ? 'disabled' : ''}>▲</button>
                            <button class="arrow-btn move-down" data-idx="${idx}" ${isLast ? 'disabled' : ''}>▼</button>
                        </div>
                    </div>
                `;
            });
            listContainer.innerHTML = itemsHtml;

            document.querySelectorAll('.move-up').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const idx = parseInt(e.target.dataset.idx);
                    if (idx > 0) {
                        [shuffledEvents[idx], shuffledEvents[idx - 1]] = [shuffledEvents[idx - 1], shuffledEvents[idx]];
                        renderList();
                    }
                });
            });

            document.querySelectorAll('.move-down').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const idx = parseInt(e.target.dataset.idx);
                    if (idx < shuffledEvents.length - 1) {
                        [shuffledEvents[idx], shuffledEvents[idx + 1]] = [shuffledEvents[idx + 1], shuffledEvents[idx]];
                        renderList();
                    }
                });
            });
        }

        const html = `
            <div style="padding:10px;">
                <h3 style="color:#113459;text-align:center;">⏳ Хронологический порядок</h3>
                <p style="text-align:center;color:#6d85a8;margin-bottom:5px;">Расставьте события от самого раннего (1) к самому позднему (6)</p>
                <p style="text-align:center;color:#6d85a8;font-size:0.85rem;">Используйте кнопки ▲▼ для перемещения</p>
                <div class="chrono-game-list" id="chronoList"></div>
                <div id="chronoResult" style="text-align:center;margin-top:20px;"></div>
                <div style="display:flex;gap:15px;justify-content:center;margin-top:20px;">
                    <button class="primary-btn" id="checkChronoBtn">✅ Проверить</button>
                    <button class="primary-btn outline" id="resetChronoBtn">🔄 Новый набор</button>
                </div>
            </div>
        `;
        viewContainer.innerHTML = html;
        renderList();

        document.getElementById('checkChronoBtn').addEventListener('click', () => {
            const currentOrder = shuffledEvents.map(ev => ev.date);
            const correctDates = correctOrder.map(ev => ev.date);
            const isCorrect = JSON.stringify(currentOrder) === JSON.stringify(correctDates);
            
            const resultDiv = document.getElementById('chronoResult');
            document.querySelectorAll('.chrono-item').forEach(el => el.classList.remove('correct', 'wrong-position'));

            if (isCorrect) {
                resultDiv.innerHTML = '<div class="result-message result-success">✅ Правильно! События в верном хронологическом порядке.</div>';
                document.querySelectorAll('.chrono-item').forEach(el => el.classList.add('correct'));
            } else {
                resultDiv.innerHTML = '<div class="result-message result-error">❌ Неправильно. Проверьте порядок событий.</div>';
                document.querySelectorAll('.chrono-item').forEach((el, idx) => {
                    if (shuffledEvents[idx].date === correctDates[idx]) {
                        el.classList.add('correct');
                    } else {
                        el.classList.add('wrong-position');
                    }
                });
                setTimeout(() => {
                    document.querySelectorAll('.chrono-item').forEach(el => el.classList.remove('wrong-position'));
                }, 1500);
            }
        });

        document.getElementById('resetChronoBtn').addEventListener('click', renderChronoOrderGame);
    }

    showTableBtn.addEventListener('click', () => { currentView = 'table'; renderTableView(); });
    showMatchBtn.addEventListener('click', () => { currentView = 'match'; renderMatchGame(); });
    showChronoOrderBtn.addEventListener('click', () => { currentView = 'chrono'; renderChronoOrderGame(); });

    renderTableView();
})();
</script>
</body>
</html>